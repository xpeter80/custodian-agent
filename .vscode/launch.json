{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Frontend (Vite Dev)",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/frontend",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "vite",
                "--port",
                "5173"
            ],
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        },
        {
            "name": "Backend (FastAPI)",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/backend/.venv/bin/python",
            "module": "uvicorn",
            "args": [
                "main:app",
                "--reload",
                "--host",
                "0.0.0.0",
                "--port",
                "8000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal"
        }
    ],
    "compounds": [
        {
            "name": "Full Stack (Frontend + Backend)",
            "configurations": [
                "Frontend (Vite Dev)",
                "Backend (FastAPI)"
            ]
        }
    ]
}